{
  "name": "agyenvoy",
  "version": "1.0.0",
  "description": "Claude Code plugin (MCP server + skill) wrapping the agy (Antigravity/Gemini) CLI",
  "type": "module",
  "main": "server.mjs",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node18 --outfile=server.mjs",
    "dev": "tsx watch src/index.ts",
    "test": "npm run build && node --test 'test/*.test.mjs'",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "clean": "rm -rf dist server.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=18"
  }
}
