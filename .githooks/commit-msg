#!/bin/sh
# Lint commit message with commitlint (Conventional Commits).
# Enable once per clone: git config core.hooksPath .githooks

if [ ! -x node_modules/.bin/commitlint ]; then
  echo "commit-msg: commitlint not installed; skipping message check (run npm install to enable)" >&2
  exit 0
fi
node_modules/.bin/commitlint --edit "$1"
